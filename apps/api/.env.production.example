# =============================================
# Gig Job Marketplace — Backend Production Env
# =============================================
# Copy and fill in production values.
# NEVER commit this file with real secrets!

# -------------------
# Server
# -------------------
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# -------------------
# Database (Managed PostgreSQL)
# -------------------
# Use the connection string from your managed DB provider (DigitalOcean, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:25060/gig_marketplace?sslmode=require
DB_HOST=your-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=gig_marketplace
DB_USER=doadmin
DB_PASSWORD=<generated-password>

# -------------------
# Auth — JWT
# -------------------
# IMPORTANT: Generate strong random secrets (≥32 chars / 256 bits)
# openssl rand -base64 48
JWT_SECRET=<generated-256-bit-secret>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<generated-256-bit-secret>
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# -------------------
# CORS
# -------------------
CORS_ORIGIN=https://gigmarketplace.vn

# -------------------
# Frontend URL (for links in emails, etc.)
# -------------------
FRONTEND_URL=https://gigmarketplace.vn

# -------------------
# Sentry — Error Tracking
# -------------------
SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456
