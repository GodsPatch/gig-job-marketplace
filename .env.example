# =============================================
# Gig Job Marketplace — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------
# Database
# -------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gig_marketplace
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gig_marketplace

# -------------------
# Backend
# -------------------
PORT=4000
NODE_ENV=development
# IMPORTANT: In production, use a strong random secret (≥32 chars / 256 bits)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
# IMPORTANT: Must also be a strong random secret for production
REFRESH_TOKEN_SECRET=your-refresh-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# -------------------
# Sentry (optional)
# -------------------
# Leave empty to disable Sentry integration
SENTRY_DSN=

# -------------------
# Frontend
# -------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SENTRY_DSN=
